# Variables de entorno para MercadoPago

# Backend - API (apps/api)
# Access Token de MercadoPago (producción o sandbox)
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXX-XXXXXXXXXXXXX-XXXXXXXXXXXXX
# URL de la API (para producción usar la URL real)
API_URL=http://localhost:3001
# URL del backoffice (para producción usar la URL real)
BACKOFFICE_URL=http://localhost:3002

# Frontend - Ecommerce (apps/ecommerce)
# Public Key de MercadoPago (producción o sandbox)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-XXXXXXXXXXXXX-XXXXXXXXXXXXX
# URL de la API
NEXT_PUBLIC_API_URL=http://localhost:3001
# WhatsApp para cotización manual de envíos si falla Correo Argentino
NEXT_PUBLIC_SHIPPING_WHATSAPP_URL=https://wa.me/549XXXXXXXXXX?text=Hola%2C%20necesito%20cotizar%20el%20env%C3%ADo%20de%20mi%20pedido%20de%20YerbaXanaes

# Backend - Correo Argentino / MiCorreo (apps/api)
# Credenciales de la API de MiCorreo. Solicitar a Correo Argentino:
# https://www.correoargentino.com.ar/MiCorreo/public/contact
CA_USER_TOKEN=
CA_PASSWORD_TOKEN=
# Credenciales del usuario de la cuenta MiCorreo (mismo email/password del portal)
CA_EMAIL=
CA_PASSWORD=
# Opcional pero recomendado: si ya tenés el customerId, acelera el startup
CA_CUSTOMER_ID=
# TEST | PROD
CA_ENVIRONMENT=TEST
# CP de origen para cotizar envíos (Villa del Rosario, Córdoba = 5963)
CA_POSTAL_CODE_ORIGIN=5963

# Datos del remitente para /shipping/import — TODOS OPCIONALES.
# Si quedan vacíos, MiCorreo usa la dirección registrada del CustomerId.
# Configurarlas solo si querés overridear o si el perfil de MiCorreo está incompleto.
CA_SENDER_NAME=
CA_SENDER_PHONE=
CA_SENDER_CELL_PHONE=
CA_SENDER_EMAIL=
CA_SENDER_STREET=
CA_SENDER_NUMBER=
CA_SENDER_FLOOR=
CA_SENDER_APARTMENT=
CA_SENDER_CITY=
# Código de provincia (B=Bs As, C=CABA, X=Córdoba, S=Santa Fe, etc.)
CA_SENDER_PROVINCE_CODE=
CA_SENDER_POSTAL_CODE=

# Backoffice — Better Auth (apps/backoffice)
# URL pública del backoffice — REQUERIDO en producción
NEXT_PUBLIC_APP_URL=http://localhost:3002
BETTER_AUTH_BASE_URL=http://localhost:3002
# Secret de Better Auth — generar con: openssl rand -hex 32
BETTER_AUTH_SECRET=
# Google OAuth — obtener en https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Lista de emails que se autoasignan rol ADMIN al hacer Google sign-in.
# Coma-separada. Cualquier otro usuario que intente registrarse será rechazado.
ADMIN_EMAILS=luzavala419@gmail.com
