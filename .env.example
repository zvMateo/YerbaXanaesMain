# Variables de entorno para MercadoPago

# Backend - API (apps/api)
# Access Token de MercadoPago (producción o sandbox)
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXX-XXXXXXXXXXXXX-XXXXXXXXXXXXX
# URL de la API (para producción usar la URL real)
API_URL=http://localhost:3001
# URL del backoffice (para producción usar la URL real)
BACKOFFICE_URL=http://localhost:3002

# Frontend - Ecommerce (apps/ecommerce)
# Public Key de MercadoPago (producción o sandbox)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=TEST-XXXXXXXXXXXXX-XXXXXXXXXXXXX
# URL de la API
NEXT_PUBLIC_API_URL=http://localhost:3001
# WhatsApp para cotización manual de envíos si falla Correo Argentino
NEXT_PUBLIC_SHIPPING_WHATSAPP_URL=https://wa.me/549XXXXXXXXXX?text=Hola%2C%20necesito%20cotizar%20el%20env%C3%ADo%20de%20mi%20pedido%20de%20YerbaXanaes
