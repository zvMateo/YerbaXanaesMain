# ============================================================
# apps/backoffice — Variables de Entorno
# ============================================================
# Copiá este archivo a .env.local y completá los valores.
# NUNCA commitees el .env.local real — protegido por .gitignore
#
# DEPLOY: En Vercel → Project Settings → Environment Variables
# ============================================================

# ------------------------------------------------------------
# API — URL del servidor NestJS
# Dev:  http://localhost:3001
# Prod: https://xxx.up.railway.app  (dominio gratuito de Railway)
# ------------------------------------------------------------
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ------------------------------------------------------------
# BETTER AUTH
# BETTER_AUTH_SECRET: mínimo 32 caracteres, generá uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# BETTER_AUTH_BASE_URL: URL base de ESTE Next.js (el backoffice)
#   Dev:  http://localhost:3002
#   Prod: https://admin.tudominio.com
# ------------------------------------------------------------
BETTER_AUTH_SECRET="cambia_esto_por_un_secreto_de_minimo_32_caracteres"
BETTER_AUTH_BASE_URL="http://localhost:3002"

# ------------------------------------------------------------
# BASE DE DATOS — La MISMA que usa la API NestJS
# En producción: copiá el DATABASE_URL de Railway (mismo addon PostgreSQL)
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/yerbaxanaes_db"

# ------------------------------------------------------------
# URL PÚBLICA DEL BACKOFFICE (para cookies y redirects de auth)
# Dev:  http://localhost:3002
# Prod: https://admin.tudominio.com
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3002"

# ------------------------------------------------------------
# GOOGLE OAUTH (Better Auth social provider)
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI DEV:  http://localhost:3002/api/auth/callback/google
# Redirect URI PROD: https://admin.tudominio.com/api/auth/callback/google
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
