# ============================================================
# apps/api - Variables de Entorno
# ============================================================
# Copi este archivo a .env y complet los valores reales.
# NUNCA commitees el .env real - est protegido por .gitignore
#
# DEPLOY: En Railway -> Settings -> Variables -> Add Variable
# ============================================================

# ------------------------------------------------------------
# BASE DE DATOS
# Railway provee DATABASE_URL automaticamente al crear el addon PostgreSQL
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/yerbaxanaes_db"

# ------------------------------------------------------------
# MERCADOPAGO
# Credenciales en: https://www.mercadopago.com.ar/developers/panel
# IMPORTANTE: Usar APP_USR- (produccion), NO credentials TEST-
# El webhook secret lo obtenes al configurar la URL en el panel de MP
# ------------------------------------------------------------
MP_ACCESS_TOKEN="APP_USR-XXXXXXXXXXXXXXXX-XXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XXXXXXXXX"
MP_WEBHOOK_SECRET="tu_webhook_secret_del_panel_mp"
MP_PENDING_ORDER_TTL_MINUTES=60
MP_PENDING_CLEANUP_INTERVAL_MINUTES=10

# ------------------------------------------------------------
# CORREO ARGENTINO
# Para calculo de envios en tiempo real
# 1. Solicitar token en: https://www.correoargentino.com.ar/micorreo
# 2. CA_ENVIRONMENT: "TEST" para sandbox, "PROD" para produccion
# ------------------------------------------------------------
CA_USER_TOKEN="tu_user_token_de_correo_argentino"
CA_PASSWORD_TOKEN="tu_password_token_de_correo_argentino"
CA_EMAIL="tu_email@correo_argentino.com"
CA_PASSWORD="tu_password_de_mi_correo"
CA_CUSTOMER_ID="tu_customer_id_se_obtiene_automticamente_la_primera_vez"
CA_ENVIRONMENT="TEST"
CA_POSTAL_CODE_ORIGIN="1000"

# ------------------------------------------------------------
# CORS - Origenes permitidos (separados por coma, sin espacios)
# Dev:  no necesario, main.ts usa fallback a localhost
# Prod: ALLOWED_ORIGINS=https://tudominio.com,https://admin.tudominio.com
# ------------------------------------------------------------
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3002"

# ------------------------------------------------------------
# URLs de frontends (para webhooks de MP y redirects)
# Prod: tus dominios reales de Vercel
# ------------------------------------------------------------
FRONTEND_URL="http://localhost:3000"
BACKOFFICE_URL="http://localhost:3002"

# ------------------------------------------------------------
# SERVIDOR
# Railway sobreescribe PORT automaticamente - no tocar en prod
# ------------------------------------------------------------
PORT=3001
NODE_ENV="development"
