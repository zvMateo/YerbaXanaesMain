// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// BETTER AUTH TABLES (Requerido por Better Auth)
// ============================================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  role          Role      @default(USER)
  phone         String?
  
  // Better Auth relations
  sessions      Session[]
  accounts      Account[]
  
  // Business relations
  address       Address?
  orders        Order[]
  ratings       ProductRating[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?   // Para credentials provider
  
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

// ============================================================
// BUSINESS TABLES
// ============================================================

enum Role {
  USER
  ADMIN
}

model Address {
  id        String  @id @default(uuid())
  street    String
  city      String
  state     String
  zip       String
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])
}

// ---------------------------------------------------------
// INVENTORY
// ---------------------------------------------------------

enum MeasurementUnit {
  GRAMS
  UNITS
}

model InventoryItem {
  id          String          @id @default(uuid())
  name        String
  sku         String?         @unique
  currentStock Int
  minStockAlert Int?
  unit        MeasurementUnit
  costPrice   Decimal?        @db.Decimal(10, 2)

  usedInVariants VariantIngredient[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------
// CATÁLOGO
// ---------------------------------------------------------

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  products    Product[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id              String    @id @default(uuid())
  name            String
  description     String?
  slug            String    @unique
  isActive        Boolean   @default(true)
  isFeatured      Boolean   @default(false)
  images          String[]
  metaTitle       String?
  metaDescription String?

  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])

  variants    ProductVariant[]
  ratings     ProductRating[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
  @@index([isActive])
}

model ProductVariant {
  id          String    @id @default(uuid())
  name        String
  price       Decimal   @db.Decimal(10, 2)
  stock       Int?
  weight      Int?      // Peso en gramos — usado para calcular envío con Correo Argentino
  sku         String?   @unique
  costPrice   Decimal?  @db.Decimal(10, 2)

  productId   String
  product     Product   @relation(fields: [productId], references: [id])

  ingredients VariantIngredient[]

  // Relación con lineas de ordenes
  orderItems  OrderItem[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([productId])
}

model VariantIngredient {
  id              String         @id @default(uuid())

  variantId       String
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  inventoryItemId String
  inventoryItem   InventoryItem  @relation(fields: [inventoryItemId], references: [id])

  quantityRequired Int

  @@unique([variantId, inventoryItemId])
}

// ---------------------------------------------------------
// VENTAS (PAYMENTS MODULE REFACTOR)
// ---------------------------------------------------------

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  REJECTED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MERCADOPAGO
  CASH
  TRANSFER
}

enum SalesChannel {
  ONLINE
  STORE
  INSTAGRAM
  WHATSAPP
  FAIR
}

// Quién/cómo cambió el estado de la orden
enum StateChangeSource {
  WEBHOOK_MERCADOPAGO  // Webhook de MP (fuente de verdad para MP)
  CHECKOUT_REDIRECT    // Redirección post-checkout
  CARD_PAYMENT_API     // Respuesta directa de Card API
  CHECKOUT_VALIDATION  // Validación de stock pre-checkout
  CLEANUP_TIMEOUT      // Timeout automático (PENDING vencido)
  MANUAL_OVERRIDE      // Cambio manual desde backoffice
  PAYMENT_REJECTED     // Rechazo inmediato de tarjeta
  RECONCILIATION       // Sincronización automática con MP
  SYSTEM_ERROR         // Error del sistema
}

model Order {
  id              String          @id @default(uuid())
  total           Decimal         @db.Decimal(10, 2)
  status          OrderStatus     @default(PENDING)
  
  // Datos del Cliente (Snapshot)
  customerEmail   String
  customerName    String?
  customerPhone   String?
  userId          String?         // Opcional: si es usuario registrado
  user            User?           @relation(fields: [userId], references: [id])

  // Canal de venta y notas internas
  channel         SalesChannel?   @default(ONLINE)
  notes           String?         // Notas internas (ej: "@usuario_ig", "Feria Palermo stand 12")

  // Datos de Pago
  paymentProvider PaymentProvider @default(MERCADOPAGO)
  mpPaymentId     String?         // ID de pago de MP
  mpStatus        String?         // Estado crudo de MP
  mpCardToken     String?         // Opcional: debugging seguro

  // Datos de Entrega
  deliveryType         String?    // "shipping" | "pickup"
  shippingAddress      String?    // Calle + número + piso/dpto (del cliente)
  shippingCity         String?    // Ciudad de destino
  shippingProvinceCode String?    // Código de provincia (A, B, C... — Correo Argentino)
  shippingZip          String?    // Código postal de destino
  shippingCost         Decimal?   @db.Decimal(10, 2)  // Costo del envío en ARS
  shippingProvider     String?    // "correo_argentino" | "flat_rate" | "pickup"

  // Tracking de Correo Argentino
  trackingNumber       String?    // Número de seguimiento (Correo Argentino)
  correoShippingId     String?    // ID del envío en el sistema de MiCorreo
  correoImportedAt     DateTime?  // Fecha en que se importó el envío a MiCorreo

  // Control de estado manual (no se revertido por webhook si está marcado)
  manualOverrideAt DateTime?      // Marca cuándo se hizo override manual (backoffice)
  manualOverrideReason String?    // Por qué se hizo override

  // Auditoría y Soft Delete
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?       // Soft Delete 🗑️

  // Relaciones
  items           OrderItem[]
  discount        OrderDiscount?
  stateChanges    OrderStateChange[]

  @@index([customerEmail])
  @@index([mpPaymentId])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([deletedAt])
  @@index([status, deletedAt])
}

model OrderItem {
  id              String          @id @default(uuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId       String
  variant         ProductVariant  @relation(fields: [variantId], references: [id])

  quantity        Int
  price           Decimal         @db.Decimal(10, 2) // Precio Snapshot

  @@index([orderId])
}

// ---------------------------------------------------------
// AUDITORÍA DE CAMBIOS DE ESTADO
// ---------------------------------------------------------

model OrderStateChange {
  id              String            @id @default(uuid())
  orderId         String
  order           Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Estados anterior y actual
  fromStatus      OrderStatus
  toStatus        OrderStatus

  // Origen del cambio (webhook, manual, cleanup, etc.)
  source          StateChangeSource

  // Contexto: si viene de webhook, guardamos los datos relevantes
  mpOrderId       String?           // ID del order de MP
  mpPaymentId     String?           // ID del payment de MP
  mpRawStatus     String?           // Status crudo de MP
  
  // Razón del cambio (para referencias cruzadas)
  reason          String?           // "webhook_processed", "manual_override", "expired_timeout", etc.

  // Auditoría: quién cambió (si fue manual)
  changedBy       String?           // User ID si fue manual
  changedByEmail  String?           // Email si fue manual
  notes           String?           // Notas adicionales

  createdAt       DateTime          @default(now())

  @@index([orderId])
  @@index([source])
  @@index([createdAt])
  @@index([mpPaymentId])
}

// ---------------------------------------------------------
// RATINGS
// ---------------------------------------------------------

model ProductRating {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  orderId    String?
  rating     Int      // 1–5
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
}

// ---------------------------------------------------------
// COUPONS
// ---------------------------------------------------------

enum DiscountType {
  PERCENTAGE
  FIXED
}

model Coupon {
  id             String        @id @default(uuid())
  code           String        @unique
  discountType   DiscountType
  discountValue  Decimal       @db.Decimal(10, 2)
  minOrderAmount Decimal?      @db.Decimal(10, 2)
  maxUses        Int?
  currentUses    Int           @default(0)
  expiresAt      DateTime?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())

  discounts      OrderDiscount[]
}

model OrderDiscount {
  id             String   @id @default(uuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id])
  discountAmount Decimal  @db.Decimal(10, 2)
}

// Configuración global de la tienda — tabla singleton (siempre 1 fila con id='singleton')
model StoreSettings {
  id                    String   @id @default("singleton")
  // Negocio
  businessName          String   @default("YerbaXanaes")
  email                 String   @default("")
  phone                 String   @default("")
  address               String   @default("")
  city                  String   @default("")
  // Envíos
  shippingEnabled       Boolean  @default(true)
  shippingFlatRate      Int      @default(1500)
  freeShippingThreshold Int      @default(15000)
  // Pagos
  paymentMercadoPago    Boolean  @default(true)
  paymentCash           Boolean  @default(true)
  paymentTransfer       Boolean  @default(true)
  // Notificaciones
  notificationEmail     String   @default("")
  lowStockAlert         Boolean  @default(true)
  lowStockThreshold     Int      @default(10)

  updatedAt             DateTime @updatedAt
}

// Tabla de deduplicación para webhooks — evita re-procesar retries duplicados de MP
model WebhookLog {
  id          String   @id @default(uuid())
  requestId   String   // x-request-id del header del webhook
  dataId      String   // id del payment/merchant_order del payload
  type        String   // "payment", "merchant_order"
  processedAt DateTime @default(now())

  @@unique([requestId, type])
  @@index([dataId, type])
  @@index([processedAt])
}
